# Скопируйте в .env и заполните значения.
# Render.com: задаются в Dashboard → Environment.

# Секретный токен для авторизации запросов к API.
# Сгенерируйте: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET=your_secret_token_here

# Содержимое credentials.json (весь JSON одной строкой).
# Скопируйте содержимое файла credentials.json сюда.
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"..."}

# Название Google-таблицы (по умолчанию VignetteCloud_Licenses).
SPREADSHEET_NAME=VignetteCloud_Licenses
